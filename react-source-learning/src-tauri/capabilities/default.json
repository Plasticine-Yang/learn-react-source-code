{
  "identifier": "default",
  "description": "Default capability set for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-delete",
    "store:allow-save",
    "store:allow-load",
    "store:allow-has",
    "store:allow-keys",
    "store:allow-values",
    "store:allow-entries",
    "store:allow-clear",
    "store:allow-reset",
    "store:allow-reload"
  ]
}
