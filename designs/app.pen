                        },
                        {
                          "type": "text",
                          "id": "cjDuJ",
                          "fill": "$--font-primary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "    performUnitOfWork(workInProgress);",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
