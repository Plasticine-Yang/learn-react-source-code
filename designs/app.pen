                      "type": "text",
                      "id": "rrTGt",
                      "fill": "$--font-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "This function creates a new Hook node and appends it to the Fiber's linked list of hooks. Notice how React initializes each field to null — they get populated during the update phase. The linked list structure is key: it's why hooks must be called in the same order every render.",
                      "lineHeight": 1.5,
                      "fontFamily": "$--font-sans",
                      "fontSize": "$--fontSize-sm",
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            }
          ]
