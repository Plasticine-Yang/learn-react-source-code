                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "ip9Dx",
                  "name": "lect",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 20,
                  "children": [
                    {
                      "type": "text",
                      "id": "aSNNm",
                      "fill": "$--font-primary",
                      "content": "The Two-Phase Architecture",
                      "fontFamily": "$--font-sans",
                      "fontSize": "$--fontSize-lg",
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "Gcqa5",
                      "fill": "$--font-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "React splits the reconciliation process into two distinct phases: the Render Phase and the Commit Phase. This separation is fundamental to understanding how React achieves both correctness and performance.\n\nDuring the Render Phase, React traverses the Fiber tree and computes what needs to change — but it does not touch the DOM. This phase can be interrupted and resumed, which is what makes Concurrent Mode possible.\n\nThe Commit Phase, by contrast, is synchronous and uninterruptible. Once React knows what changes are needed, it commits them to the DOM in one atomic operation.",
                      "lineHeight": 1.8,
                      "fontFamily": "$--font-sans",
                      "fontSize": "$--fontSize-base",
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "nBWH9",
                      "name": "codeF",
                      "width": "fill_container",
                      "fill": "$--bg-tertiary",
                      "cornerRadius": "$--radius-lg",
                      "stroke": {
                        "align": "inside",
                        "thickness": 1,
                        "fill": "$--border-color"
                      },
                      "layout": "vertical",
                      "children": [
                        {
                          "type": "frame",
                          "id": "r1gYSd",
                          "name": "codeFH",
                          "width": "fill_container",
                          "stroke": {
                            "align": "inside",
                            "thickness": {
                              "bottom": 1
                            },
                            "fill": "$--border-color"
                          },
                          "padding": [
                            8,
                            14
                          ],
                          "justifyContent": "space_between",
                          "alignItems": "center",
                          "children": [
                            {
                              "type": "text",
                              "id": "nYleS",
                              "fill": "$--accent-blue",
                              "content": "ReactFiberWorkLoop.js",
                              "fontFamily": "$--font-mono",
                              "fontSize": "$--fontSize-xs",
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "GRgGS",
                              "fill": "$--font-secondary",
                              "content": "L415-432",
                              "fontFamily": "$--font-mono",
                              "fontSize": "$--fontSize-xs",
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "ZiuuM",
                          "name": "codeFB",
                          "width": "fill_container",
                          "layout": "vertical",
                          "padding": 14,
                          "children": [
                            {
                              "type": "text",
                              "id": "yk44a",
                              "fill": "$--font-primary",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "function workLoopSync() {\n  while (workInProgress !== null) {\n    performUnitOfWork(workInProgress);\n  }\n}\n\nfunction workLoopConcurrent() {\n  while (workInProgress !== null && !shouldYield()) {\n    performUnitOfWork(workInProgress);\n  }\n}",
                              "lineHeight": 1.7,
                              "fontFamily": "$--font-mono",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "id": "v6jUR",
                      "type": "ref",
                      "ref": "sZQ6O",
                      "width": 280,
                      "name": "askBtn",
                      "descendants": {
                        "doTNg": {
                          "iconFontName": "message-circle"
                        },
                        "l9noz": {
                          "content": "Ask AI to Explain This Code"
                        }
                      }
                    },
                    {
                      "type": "text",
                      "id": "QnEVx",
                      "fill": "$--font-primary",
                      "content": "Why Two Phases?",
                      "fontFamily": "$--font-sans",
                      "fontSize": "$--fontSize-lg",
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "cyXpM",
                      "fill": "$--font-secondary",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "The key insight is that the render phase can be interrupted. When you type in an input, React needs to prioritize that update over whatever background work it was doing. The concurrent work loop checks shouldYield() on every unit of work — if something higher priority came in, React pauses the current render and yields to the browser.\n\nThis means the render phase might run multiple times before a single commit. Each time, React builds a new workInProgress tree, comparing against the current tree that was last committed to the DOM.",
                      "lineHeight": 1.8,
                      "fontFamily": "$--font-sans",
                      "fontSize": "$--fontSize-base",
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "q8bBVv",
                  "name": "navB",
                  "width": "fill_container",
                  "stroke": {
                    "align": "inside",
