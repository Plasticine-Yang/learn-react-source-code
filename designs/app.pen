                                  "id": "xCcVC",
                                  "fill": "$--font-primary",
                                  "content": "function mountWorkInProgressHook(): Hook {",
                                  "lineHeight": 1.7,
                                  "fontFamily": "$--font-mono",
                                  "fontSize": 12,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "Zmwu0",
                          "fill": "$--font-primary",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "  const hook: Hook = {\n    memoizedState: null,\n    baseState: null,\n    baseQueue: null,\n    queue: null,\n    next: null,\n  };\n  if (workInProgressHook === null) {\n    currentlyRenderingFiber.memoizedState = hook;\n  } else {\n    workInProgressHook = workInProgressHook.next = hook;\n  }\n  workInProgressHook = hook;\n  return workInProgressHook;\n}",
                          "lineHeight": 1.7,
                          "fontFamily": "$--font-mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
                        }
                      ]
                    }
