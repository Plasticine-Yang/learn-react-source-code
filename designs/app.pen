                    {
                      "type": "text",
                      "id": "G8Met",
                      "fill": "$--font-primary",
                      "content": "2.3 Render Phase & Commit Phase",
                      "fontFamily": "$--font-sans",
                      "fontSize": "$--fontSize-2xl",
                      "fontWeight": "700"
                    },
                    {
                      "type": "frame",
                      "id": "lCFGW",
                      "name": "mhMeta",
                      "width": "fill_container",
                      "gap": 16,
                      "alignItems": "center",
                      "children": [
                        {
                          "type": "text",
                          "id": "Jpfq1",
                          "fill": "$--accent-blue",
                          "content": "Module 2: Fiber Architecture",
                          "fontFamily": "$--font-sans",
                          "fontSize": "$--fontSize-sm",
                          "fontWeight": "500"
                        },
                        {
                          "type": "text",
                          "id": "OvMFo",
                          "fill": "$--font-secondary",
                          "content": "Est. reading: 35 min",
                          "fontFamily": "$--font-sans",
